# Ticketmaster Discovery API (free - https://developer.ticketmaster.com/)
TICKETMASTER_API_KEY=your_key_here

# SeatGeek API (free - https://seatgeek.com/build)
SEATGEEK_CLIENT_ID=your_client_id_here

# Yelp Fusion API (free - https://www.yelp.com/developers)
YELP_API_KEY=your_key_here

# Unsplash API (free - https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_key_here

# Pexels API (free - https://www.pexels.com/api/)
PEXELS_API_KEY=your_key_here

# Anthropic Claude API (for AI category classification)
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# CloudKit Server-to-Server
# Create key at https://icloud.developer.apple.com → API Access → Server-to-Server Keys
CLOUDKIT_CONTAINER=iCloud.com.parentguide.app
CLOUDKIT_KEY_ID=your_key_id
CLOUDKIT_ENVIRONMENT=development
# Use ONE of these — raw key content for CI, file path for local dev
CLOUDKIT_PRIVATE_KEY_PATH=./cloudkit-key.pem
# CLOUDKIT_PRIVATE_KEY=<paste full PEM content>
